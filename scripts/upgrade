#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# ENSURE DOWNWARD COMPATIBILITY
#=================================================
ynh_script_progression "Ensuring downward compatibility..."

if ynh_app_upgrading_from_version_before 0.19.1~ynh1; then
	ynh_die "You should first upgrade to version 0.19.1~ynh1 before upgrading to a newer version. You can use the following command: yunohost app upgrade gotosocial -u https://github.com/YunoHost-Apps/gotosocial_ynh/tree/388d9cf9d12b9485fe9317f1dd6fa2433c8b5864"
fi

# 0.17.3~ynh2 (2025-02-10)
ynh_app_setting_set_default --key=storage_s3_redirect_url --value=""

# 0.19.0~ynh3 (2025-05-05)
ynh_app_setting_set_default --key=instance_languages --value=""

# workaround for https://github.com/YunoHost/issues/issues/2422
ynh_app_setting_set --key=protect_against_basic_auth_spoofing --value=False

# 0.20.0~ynh1 (2025-10-08)
if [ -z "${instance_expose_blocklist:-}" ]; then
	ynh_app_setting_set_default --key=instance_expose_blocklist --value=$instance_expose_suspended
	ynh_app_setting_set_default --key=instance_expose_blocklist_web --value=$instance_expose_suspended_web
	ynh_app_setting_delete --key=instance_expose_suspended
	ynh_app_setting_delete --key=instance_expose_suspended_web
fi
ynh_app_setting_set_default --key=instance_expose_allowlist --value="false"
ynh_app_setting_set_default --key=instance_expose_allowlist_web --value="false"
ynh_app_setting_set_default --key=instance_expose_custom_emojis --value="false"
if [ $media_description_max_chars == "1500" ]; then  # if it's still the old default value, set the new default value
	media_description_max_chars="5000"
	ynh_app_setting_set --key=media_description_max_chars --value="5000"
fi
ynh_app_setting_set_default --key=accounts_max_profile_fields --value="6"
ynh_app_setting_set_default --key=storage_s3_bucket_lookup  --value="auto"
ynh_app_setting_delete --key=metrics_auth_enabled
ynh_app_setting_delete --key=metrics_auth_username
ynh_app_setting_delete --key=metrics_auth_password

smtp_host="$domain"
smtp_port="587"
ynh_app_setting_set --key=smtp_host --value="$smtp_host"
ynh_app_setting_set --key=smtp_port --value="$smtp_port"

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

nowasm_detection
ynh_setup_source --dest_dir="$install_dir" --source_id="$build_version" --full_replace --keep="config.yaml .cache"

mkdir -p "$install_dir/.cache"
chown -R "$app:www-data" "$install_dir/.cache"
chmod -R 750 "$install_dir/.cache"

#=================================================
# UPDATE A CONFIG FILE
#=================================================
ynh_script_progression "Updating $app's configuration files..."

ynh_config_add --template="config.yaml" --destination="$install_dir/config.yaml"

#=================================================
# REAPPLY SYSTEM CONFIGURATIONS
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

ynh_config_add_nginx

ynh_config_add_systemd

yunohost service add "$app" --description="Gotosocial server" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

ynh_config_add_fail2ban --logpath="/var/log/${app}/${app}.log" --failregex="statusCode=401 path=/auth/sign_in clientIP=<HOST> .* msg=\"Unauthorized:"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

# huge timeout of 30 minutes because database migrations can be quite long...
ynh_systemctl --service="$app" --action="start"  --wait_until="listening on" --timeout=1800

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
